<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:EasyImmoMaui.ViewsModels"
             xmlns:dal="clr-namespace:DAL.DB;assembly=DAL"
             x:Class="EasyImmoMaui.MainPage"
             x:DataType="viewmodels:PropertyPageViewModel"
             Title="Détail du bien"
             BackgroundColor="Black">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="12">

            <HorizontalStackLayout Spacing="8">
                <Label Text="ID :" FontAttributes="Bold" />
                <Label Text="{Binding IdBien}" />
            </HorizontalStackLayout>

            <HorizontalStackLayout Spacing="8">
                <Label Text="Type :" FontAttributes="Bold" />
                <Label Text="{Binding TypeBien}" />
            </HorizontalStackLayout>

            <HorizontalStackLayout Spacing="8">
                <Label Text="Statut :" FontAttributes="Bold" />
                <Label Text="{Binding Statut}" />
            </HorizontalStackLayout>

            <Label Text="Description :" FontAttributes="Bold" />
            <Label Text="{Binding Description}" />

            <BoxView HeightRequest="1" BackgroundColor="LightGray" Margin="0,10" />

            <Label Text="Derniers évènements :" FontAttributes="Bold" FontSize="16" />

            <CollectionView ItemsSource="{Binding Activites}">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="dal:Activite">
                        <Frame Margin="0,4" Padding="10" BorderColor="LightGray" CornerRadius="6">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="{Binding LibelleActivite}" FontAttributes="Bold" />
                                <Label Text="{Binding DateActivite, StringFormat='Date : {0:dd/MM/yyyy}'}" />
                                <Label Text="{Binding DureeActivite, StringFormat='Durée : {0}'}" />
                            </VerticalStackLayout>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
