<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:EasyImmoMaui.ViewModels"
             xmlns:helpers="clr-namespace:EasyImmoMaui.Helpers"
             x:Class="EasyImmoMaui.MainPage"
             BackgroundColor="#F5F5F5">

    <ContentPage.Resources>
        <vm:MenuActifConverter x:Key="MenuActifConverter"/>
    </ContentPage.Resources>

    <Grid ColumnDefinitions="220,*">

        <!-- SlideBar -->
        <Grid Grid.Column="0" BackgroundColor="#0F1729" RowDefinitions="Auto,*">

            <!-- Logo  -->
            <VerticalStackLayout Grid.Row="0" Padding="10,15" Spacing="0">
                <Image Source="easyimmo_logo.png"
                   HeightRequest="200"
                   Aspect="AspectFit"/>
                <BoxView HeightRequest="1"
                     Margin="0,15,0,0"/>   
            </VerticalStackLayout>
            
            <!-- Menu -->
            <VerticalStackLayout Grid.Row="1" Padding="10,20" Spacing="5">

                <!-- Tableau de bord -->
                <Border BackgroundColor="{Binding MenuActif, Converter={StaticResource MenuActifConverter}, ConverterParameter=TableauDeBord}"
                    StrokeShape="RoundRectangle 8"
                    Stroke="Transparent"
                    Padding="15,12">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="NaviguerTableauDeBord"/>
                    </Border.GestureRecognizers>
                    <HorizontalStackLayout Spacing="15">
                        <Label Text="{x:Static helpers:Icons.Tableaudebord}"
                           FontFamily="FontAwesome"
                           FontSize="20"
                           TextColor="White"
                           VerticalOptions="Center"/>
                        <Label Text="Tableau de bord" TextColor="White" FontSize="16" VerticalOptions="Center"/>
                    </HorizontalStackLayout>
                </Border>
                <!-- Biens -->
                <Border BackgroundColor="{Binding MenuActif, Converter={StaticResource MenuActifConverter}, ConverterParameter=Biens}"
                        StrokeShape="RoundRectangle 8"
                        Stroke="Transparent"
                        Padding="15,12">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="NaviguerBiens"/>
                    </Border.GestureRecognizers>
                    <HorizontalStackLayout Spacing="15">
                        <Label Text="{x:Static helpers:Icons.Immeuble}"
                               FontFamily="FontAwesome"
                               FontSize="20"
                               TextColor="White"
                               VerticalOptions="Center"/>
                        <Label Text="Biens" TextColor="White" FontSize="16" VerticalOptions="Center"/>
                    </HorizontalStackLayout>
                </Border>

                <!--  Clients -->
                <Border BackgroundColor="{Binding MenuActif, Converter={StaticResource MenuActifConverter}, ConverterParameter=Clients}"
                        StrokeShape="RoundRectangle 8"
                        Stroke="Transparent"
                        Padding="15,12">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="NaviguerClients"/>
                    </Border.GestureRecognizers>
                    <HorizontalStackLayout Spacing="15">
                        <Label Text="{x:Static helpers:Icons.Utilisateur}"
                               FontFamily="FontAwesome"
                               FontSize="20"
                               TextColor="White"
                               VerticalOptions="Center"/>
                        <Label Text="Clients" TextColor="White" FontSize="16" VerticalOptions="Center"/>
                    </HorizontalStackLayout>
                </Border>

                <!-- Activités -->
                <Border BackgroundColor="{Binding MenuActif, Converter={StaticResource MenuActifConverter}, ConverterParameter=Activites}"
                        StrokeShape="RoundRectangle 8"
                        Stroke="Transparent"
                        Padding="15,12">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="NaviguerActivites"/>
                    </Border.GestureRecognizers>
                    <HorizontalStackLayout Spacing="15">
                        <Label Text="{x:Static helpers:Icons.Calendrier}"
                               FontFamily="FontAwesome"
                               FontSize="20"
                               TextColor="White"
                               VerticalOptions="Center"/>
                        <Label Text="Activités" TextColor="White" FontSize="16" VerticalOptions="Center"/>
                    </HorizontalStackLayout>
                </Border>

                <!-- Opérations -->
                <Border BackgroundColor="{Binding MenuActif, Converter={StaticResource MenuActifConverter}, ConverterParameter=Operations}"
                        StrokeShape="RoundRectangle 8"
                        Stroke="Transparent"
                        Padding="15,12">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="NaviguerOperations"/>
                    </Border.GestureRecognizers>
                    <HorizontalStackLayout Spacing="15">
                        <Label Text="{x:Static helpers:Icons.Document}"
                               FontFamily="FontAwesome"
                               FontSize="20"
                               TextColor="White"
                               VerticalOptions="Center"/>
                        <Label Text="Opérations" TextColor="White" FontSize="16" VerticalOptions="Center"/>
                    </HorizontalStackLayout>
                </Border>

                <!-- Paramètres -->
                <Border BackgroundColor="{Binding MenuActif, Converter={StaticResource MenuActifConverter}, ConverterParameter=Parametres}"
                        StrokeShape="RoundRectangle 8"
                        Stroke="Transparent"
                        Padding="15,12">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="NaviguerParametres"/>
                    </Border.GestureRecognizers>
                    <HorizontalStackLayout Spacing="15">
                        <Label Text="{x:Static helpers:Icons.Parametres}"
                               FontFamily="FontAwesome"
                               FontSize="20"
                               TextColor="White"
                               VerticalOptions="Center"/>
                        <Label Text="Paramètres" TextColor="White" FontSize="16" VerticalOptions="Center"/>
                    </HorizontalStackLayout>
                </Border>
            </VerticalStackLayout>
        </Grid>

        <!-- Zone centrale top -->
        <Grid Grid.Column="1" RowDefinitions="Auto,*">

            <!-- En-tête avec titre et l'utilisateur -->
                 <Grid Grid.Row="0"
                  BackgroundColor="White"
                  ColumnDefinitions="*,Auto"
                  Padding="30,15">  

                <VerticalStackLayout Grid.Column="0" VerticalOptions="Center">
                    <Label Text="{Binding TitrePage}"
                       FontSize="22"
                       FontAttributes="Bold"
                       TextColor="#1a1a1a"/>
                    <Label Text="{Binding SousTitre}"
                       FontSize="12"
                       TextColor="#888"/>
                </VerticalStackLayout>


                <HorizontalStackLayout Grid.Column="1" Spacing="10" VerticalOptions="Center">
                    <Border BackgroundColor="#5B4FE9"
                        StrokeShape="RoundRectangle 20"
                        Stroke="Transparent"
                        WidthRequest="40"
                        HeightRequest="40">
                        <Label Text="V"
                           TextColor="White"
                           FontSize="16"
                           FontAttributes="Bold"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"/>
                    </Border>
                    <VerticalStackLayout VerticalOptions="Center">
                        <Label Text="Verdiane"
                           FontSize="14"
                           FontAttributes="Bold"
                           TextColor="#1a1a1a"/>
                        <Label Text="Agent immobilier"
                           FontSize="11"
                           TextColor="#888"/>
                    </VerticalStackLayout>
                </HorizontalStackLayout>
            </Grid>

            <!-- Zone qui change en fonction de la page actuelle -->
            <ContentView Grid.Row="1" Content="{Binding CurrentView}"/>
        </Grid>
    </Grid>
</ContentPage>