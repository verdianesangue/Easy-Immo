<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:EasyImmoMaui.ViewModels"
             x:Class="EasyImmoMaui.Views.ActiviteFormulairePopup"
             BackgroundColor="#80000000">

    <Grid Padding="30">
        <Border BackgroundColor="White"
                StrokeShape="RoundRectangle 15"
                Stroke="Transparent"
                Padding="30"
                MaximumWidthRequest="600"
                VerticalOptions="Center"
                HorizontalOptions="Center">

            <ScrollView>
                <VerticalStackLayout Spacing="15">

                    <!-- Titre -->
                    <Label Text="{Binding TitrePopup}"
                           FontSize="22"
                           FontAttributes="Bold"
                           TextColor="#1E40AF" />

                    <!-- Libellé -->
                    <Label Text="Libellé" 
                           FontAttributes="Bold" 
                           TextColor="#333"
                           FontSize="14"
                           Margin="0,10,0,0"/>
                    <Border BackgroundColor="#F5F5F5"
                            StrokeShape="RoundRectangle 8"
                            Stroke="Transparent"
                            Padding="15,5">
                        <Entry Text="{Binding Libelle}"
                               Placeholder="Ex: Visite appartement Bruxelles"
                               BackgroundColor="Transparent"
                               TextColor="#333"
                               PlaceholderColor="#888"
                               FontSize="14"/>
                    </Border>

                    <!-- Type -->
                    <Label Text="Type d'activité" 
                           FontAttributes="Bold" 
                           TextColor="#333"
                           FontSize="14"
                           Margin="0,10,0,0"/>
                    <Border BackgroundColor="#F5F5F5"
                            StrokeShape="RoundRectangle 8"
                            Stroke="Transparent"
                            Padding="15,5">
                        <Picker ItemsSource="{Binding TypesDisponibles}"
                                SelectedItem="{Binding TypeSelectionne}"
                                TextColor="#333"
                                BackgroundColor="Transparent"
                                FontSize="14"/>
                    </Border>

                    <!-- Bien concerné -->
                    <Label Text="Bien concerné" 
                           FontAttributes="Bold" 
                           TextColor="#333"
                           FontSize="14"
                           Margin="0,10,0,0"/>
                    <Border BackgroundColor="#F5F5F5"
                            StrokeShape="RoundRectangle 8"
                            Stroke="Transparent"
                            Padding="15,5">
                        <Picker ItemsSource="{Binding BiensDisponibles}"
                                SelectedItem="{Binding BienSelectionne}"
                                ItemDisplayBinding="{Binding NomBien}"
                                TextColor="#333"
                                BackgroundColor="Transparent"
                                FontSize="14"/>
                    </Border>

                    <!-- Date -->
                    <Label Text="Date" 
                           FontAttributes="Bold" 
                           TextColor="#333"
                           FontSize="14"
                           Margin="0,10,0,0"/>
                    <Border BackgroundColor="#F5F5F5"
                            StrokeShape="RoundRectangle 8"
                            Stroke="Transparent"
                            Padding="15,5">
                        <DatePicker Date="{Binding DateActivite}"
                                    TextColor="#333"
                                    BackgroundColor="Transparent"
                                    FontSize="14"/>
                    </Border>

                    <!-- Heure -->
                    <Label Text="Heure" 
                           FontAttributes="Bold" 
                           TextColor="#333"
                           FontSize="14"
                           Margin="0,10,0,0"/>
                    <Border BackgroundColor="#F5F5F5"
                            StrokeShape="RoundRectangle 8"
                            Stroke="Transparent"
                            Padding="15,5">
                        <TimePicker Time="{Binding HeureActivite}"
                                    TextColor="#333"
                                    BackgroundColor="Transparent"
                                    FontSize="14"/>
                    </Border>

                    <!-- Durée -->
                    <Label Text="Durée" 
                           FontAttributes="Bold" 
                           TextColor="#333"
                           FontSize="14"
                           Margin="0,10,0,0"/>
                    <Border BackgroundColor="#F5F5F5"
                            StrokeShape="RoundRectangle 8"
                            Stroke="Transparent"
                            Padding="15,5">
                        <TimePicker Time="{Binding DureeActivite}"
                                    TextColor="#333"
                                    BackgroundColor="Transparent"
                                    FontSize="14"/>
                    </Border>

                    <!-- Boutons -->
                    <HorizontalStackLayout Spacing="10" 
                                           HorizontalOptions="End" 
                                           Margin="0,20,0,0">
                        <Border BackgroundColor="#E0E0E0"
                                StrokeShape="RoundRectangle 25"
                                Stroke="Transparent"
                                Padding="25,12">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="Annuler"/>
                            </Border.GestureRecognizers>
                            <Label Text="Annuler"
                                   TextColor="#333"
                                   FontSize="14"
                                   FontAttributes="Bold"
                                   VerticalOptions="Center"/>
                        </Border>

                        <Border BackgroundColor="#1E40AF"
                                StrokeShape="RoundRectangle 25"
                                Stroke="Transparent"
                                Padding="25,12">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="Enregistrer"/>
                            </Border.GestureRecognizers>
                            <Label Text="Enregistrer"
                                   TextColor="White"
                                   FontSize="14"
                                   FontAttributes="Bold"
                                   VerticalOptions="Center"/>
                        </Border>
                    </HorizontalStackLayout>

                </VerticalStackLayout>
            </ScrollView>
        </Border>
    </Grid>
</ContentPage>