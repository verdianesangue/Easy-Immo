<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:EasyImmoMaui.ViewModels"
             xmlns:helpers="clr-namespace:EasyImmoMaui.Helpers"
             x:Class="EasyImmoMaui.Views.ClientsView">

    <Grid Padding="25" RowSpacing="20" RowDefinitions="Auto,*">

        <!-- Barre de recherche et bouton Ajouter -->
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" ColumnSpacing="15">

            <!-- Barre de recherche -->
            <Border Grid.Column="0"
                    BackgroundColor="White"
                    StrokeShape="RoundRectangle 30"
                    Stroke="Transparent"
                    Padding="20,12">
                <HorizontalStackLayout Spacing="10">
                    <Label Text="{x:Static helpers:Icons.Loupe}"
                           FontFamily="FontAwesome"
                           FontSize="16"
                           TextColor="#888"
                           VerticalOptions="Center"/>
                    <Entry Placeholder="Rechercher un client..."
                           Text="{Binding TexteRecherche, Mode=TwoWay}"
                           TextChanged="Rechercher"
                           BackgroundColor="Transparent"
                           TextColor="#333"
                           PlaceholderColor="#888"
                           FontSize="14"
                           WidthRequest="500"
                           VerticalOptions="Center"/>
                </HorizontalStackLayout>
            </Border>

            <!-- Bouton Ajouter un client -->
            <Border Grid.Column="1"
                    BackgroundColor="#1E40AF"
                    StrokeShape="RoundRectangle 30"
                    Stroke="Transparent"
                    Padding="25,12">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="Ajouter"/>
                </Border.GestureRecognizers>
                <HorizontalStackLayout Spacing="10">
                    <Label Text="{x:Static helpers:Icons.Plus}"
                           FontFamily="FontAwesome"
                           FontSize="14"
                           TextColor="White"
                           VerticalOptions="Center"/>
                    <Label Text="Ajouter un client"
                           TextColor="White"
                           FontSize="14"
                           FontAttributes="Bold"
                           VerticalOptions="Center"/>
                </HorizontalStackLayout>
            </Border>
        </Grid>

        <!-- Tableau des clients -->
        <Border Grid.Row="1"
                BackgroundColor="White"
                StrokeShape="RoundRectangle 12"
                Stroke="Transparent"
                Padding="0">

            <Grid RowDefinitions="Auto,*">

                <!-- En-tête du tableau -->
                <Grid Grid.Row="0"
                      BackgroundColor="White"
                      ColumnDefinitions="2*,2*,2.5*,2*,2.5*,Auto"
                      Padding="20,15"
                      ColumnSpacing="15">
                    <Label Grid.Column="0" Text="Nom"       FontAttributes="Bold" FontSize="14" TextColor="#333"/>
                    <Label Grid.Column="1" Text="Prénom"    FontAttributes="Bold" FontSize="14" TextColor="#333"/>
                    <Label Grid.Column="2" Text="Email"     FontAttributes="Bold" FontSize="14" TextColor="#333"/>
                    <Label Grid.Column="3" Text="Téléphone" FontAttributes="Bold" FontSize="14" TextColor="#333"/>
                    <Label Grid.Column="4" Text="Rôles"     FontAttributes="Bold" FontSize="14" TextColor="#333"/>
                    <Label Grid.Column="5" Text="Action"    FontAttributes="Bold" FontSize="14" TextColor="#333"
                           HorizontalOptions="Center"
                           MinimumWidthRequest="100"/>
                </Grid>

                <BoxView Grid.Row="0"
                         HeightRequest="1"
                         BackgroundColor="#EEE"
                         VerticalOptions="End"/>

                <!-- Liste des clients -->
                <CollectionView Grid.Row="1"
                                ItemsSource="{Binding Clients}"
                                SelectionMode="None">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Grid ColumnDefinitions="2*,2*,2.5*,2*,2.5*,Auto"
                                  Padding="20,15"
                                  ColumnSpacing="15">

                                <!-- Nom -->
                                <Label Grid.Column="0"
                                       Text="{Binding Nom}"
                                       FontSize="14"
                                       FontAttributes="Bold"
                                       TextColor="#333"
                                       VerticalOptions="Center"/>

                                <!-- Prénom -->
                                <Label Grid.Column="1"
                                       Text="{Binding Prenom}"
                                       FontSize="14"
                                       TextColor="#333"
                                       VerticalOptions="Center"/>

                                <!-- Email -->
                                <Label Grid.Column="2"
                                       Text="{Binding Email}"
                                       FontSize="13"
                                       TextColor="#555"
                                       VerticalOptions="Center"
                                       LineBreakMode="TailTruncation"/>

                                <!-- Téléphone -->
                                <Label Grid.Column="3"
                                       Text="{Binding Telephone}"
                                       FontSize="13"
                                       TextColor="#555"
                                       VerticalOptions="Center"/>

                                <!-- Rôles -->
                                <Label Grid.Column="4"
                                       Text="{Binding RolesAffichage}"
                                       FontSize="13"
                                       TextColor="#1E40AF"
                                       FontAttributes="Bold"
                                       VerticalOptions="Center"/>

                                <!-- Boutons Action -->
                                <HorizontalStackLayout Grid.Column="5"
                                                       Spacing="8"
                                                       VerticalOptions="Center">

                                    <!-- Bouton Modifier -->
                                    <Border BackgroundColor="#FFF3E0"
                                            StrokeShape="RoundRectangle 6"
                                            Stroke="Transparent"
                                            Padding="10,8">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="Modifier"/>
                                        </Border.GestureRecognizers>
                                        <Label Text="{x:Static helpers:Icons.Modifier}"
                                               FontFamily="FontAwesome"
                                               FontSize="14"
                                               TextColor="#F57C00"/>
                                    </Border>

                                    <!-- Bouton Supprimer -->
                                    <Border BackgroundColor="#FFEBEE"
                                            StrokeShape="RoundRectangle 6"
                                            Stroke="Transparent"
                                            Padding="10,8">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="Supprimer"/>
                                        </Border.GestureRecognizers>
                                        <Label Text="{x:Static helpers:Icons.Poubelle}"
                                               FontFamily="FontAwesome"
                                               FontSize="14"
                                               TextColor="#C62828"/>
                                    </Border>

                                </HorizontalStackLayout>
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </Grid>
        </Border>
    </Grid>
</ContentView>