<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:helpers="clr-namespace:EasyImmoMaui.Helpers"
             xmlns:bu="clr-namespace:BU;assembly=BU"
             x:Class="EasyImmoMaui.Views.ContratFormulairePopup"
             BackgroundColor="#80000000">

    <Grid VerticalOptions="Center" HorizontalOptions="Center" Padding="20">
        <Border BackgroundColor="White"
                StrokeShape="RoundRectangle 15"
                Stroke="Transparent"
                Padding="0"
                WidthRequest="620">

            <Grid RowDefinitions="Auto,*,Auto">

                <!-- En-tête -->
                <Grid Grid.Row="0" BackgroundColor="#F0F0F0"
                      ColumnDefinitions="*,Auto" Padding="20,15">
                    <Label Grid.Column="0" Text="{Binding Titre}"
                           FontSize="18" FontAttributes="Bold"
                           TextColor="#1a1a1a" VerticalOptions="Center"/>
                    <Border Grid.Column="1" BackgroundColor="Transparent" Padding="8,4">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="Annuler"/>
                        </Border.GestureRecognizers>
                        <Label Text="{x:Static helpers:Icons.Croix}"
                               FontFamily="FontAwesome" FontSize="18" TextColor="#666"/>
                    </Border>
                </Grid>

                <!-- Formulaire -->
                <ScrollView Grid.Row="1">
                    <VerticalStackLayout Padding="30" Spacing="15">

                        <!-- Type de contrat -->
                        <Grid ColumnDefinitions="130,*" ColumnSpacing="15">
                            <Label Grid.Column="0" Text="Type" FontSize="14"
                                   TextColor="#333" VerticalOptions="Center" HorizontalOptions="End"/>
                            <Border Grid.Column="1" Stroke="#CCC"
                                    StrokeShape="RoundRectangle 6" Padding="10,0">
                                <Picker ItemsSource="{Binding TypesContrat}"
                                        SelectedItem="{Binding TypeContrat, Mode=TwoWay}"
                                        BackgroundColor="Transparent" TextColor="#333" FontSize="14"/>
                            </Border>
                        </Grid>

                        <!-- Description -->
                        <Grid ColumnDefinitions="130,*" ColumnSpacing="15">
                            <Label Grid.Column="0" Text="Description" FontSize="14"
                                   TextColor="#333" VerticalOptions="Center" HorizontalOptions="End"/>
                            <Border Grid.Column="1" Stroke="#CCC"
                                    StrokeShape="RoundRectangle 6" Padding="10,0">
                                <Entry Text="{Binding Description, Mode=TwoWay}"
                                       BackgroundColor="Transparent" TextColor="#333"
                                       Placeholder="Ex: Acte de vente Les Cerisiers" FontSize="14"/>
                            </Border>
                        </Grid>

                        <!-- Date -->
                        <Grid ColumnDefinitions="130,*" ColumnSpacing="15">
                            <Label Grid.Column="0" Text="Date" FontSize="14"
                                   TextColor="#333" VerticalOptions="Center" HorizontalOptions="End"/>
                            <Border Grid.Column="1" Stroke="#CCC"
                                    StrokeShape="RoundRectangle 6" Padding="10,0">
                                <DatePicker Date="{Binding DateOperation, Mode=TwoWay}"
                                            BackgroundColor="Transparent" TextColor="#333" FontSize="14"/>
                            </Border>
                        </Grid>

                        <!-- Bien -->
                        <Grid ColumnDefinitions="130,*" ColumnSpacing="15">
                            <Label Grid.Column="0" Text="Bien concerné" FontSize="14"
                                   TextColor="#333" VerticalOptions="Center" HorizontalOptions="End"/>
                            <Border Grid.Column="1" Stroke="#CCC"
                                    StrokeShape="RoundRectangle 6" Padding="10,0">
                                <Picker ItemsSource="{Binding BiensDisponibles}"
                                        SelectedItem="{Binding BienSelectionne, Mode=TwoWay}"
                                        ItemDisplayBinding="{Binding NomBien}"
                                        BackgroundColor="Transparent" TextColor="#333"
                                        Title="Choisir un bien" FontSize="14"/>
                            </Border>
                        </Grid>

                        

                        
                        <Label Text="Parties signataires"
                               FontSize="14" FontAttributes="Bold"
                               TextColor="#1E40AF" Margin="0,10,0,0"/>

                        <!-- Agent immobilier -->
                        <Grid ColumnDefinitions="130,*" ColumnSpacing="15">
                            <Label Grid.Column="0" Text="Agent" FontSize="14"
                                   TextColor="#333" VerticalOptions="Center" HorizontalOptions="End"/>
                            <Border Grid.Column="1" Stroke="#CCC"
                                    StrokeShape="RoundRectangle 6" Padding="10,0">
                                <Picker ItemsSource="{Binding AgentsDisponibles}"
                                        SelectedItem="{Binding AgentSelectionne, Mode=TwoWay}"
                                        BackgroundColor="Transparent" TextColor="#333"
                                        Title="Aucun" FontSize="14"/>
                            </Border>
                        </Grid>

                        <!-- Acheteur ou Locataire  -->
                        <Grid ColumnDefinitions="130,*" ColumnSpacing="15">
                            <Label Grid.Column="0" Text="{Binding LabelParticipant}"
                                   FontSize="14" TextColor="#333"
                                   VerticalOptions="Center" HorizontalOptions="End"/>
                            <Border Grid.Column="1" Stroke="#CCC"
                                    StrokeShape="RoundRectangle 6" Padding="10,0">
                                <Picker x:Name="PickerParticipant"
                                        SelectedItem="{Binding ParticipantSelectionne, Mode=TwoWay}"
                                        BackgroundColor="Transparent" TextColor="#333"
                                        Title="Aucun" FontSize="14"/>
                            </Border>
                        </Grid>

                        <!-- Propriétaire -->
                        <Grid ColumnDefinitions="130,*" ColumnSpacing="15">
                            <Label Grid.Column="0" Text="Propriétaire" FontSize="14"
                                   TextColor="#333" VerticalOptions="Center" HorizontalOptions="End"/>
                            <Border Grid.Column="1" Stroke="#CCC"
                                    StrokeShape="RoundRectangle 6" Padding="10,0">
                                <Picker ItemsSource="{Binding ProprietairesDisponibles}"
                                        SelectedItem="{Binding ProprietaireSelectionne, Mode=TwoWay}"
                                        BackgroundColor="Transparent" TextColor="#333"
                                        Title="Aucun" FontSize="14"/>
                            </Border>
                        </Grid>

                    </VerticalStackLayout>
                </ScrollView>

                <!-- Boutons -->
                <Grid Grid.Row="2" ColumnDefinitions="*,Auto,Auto"
                      Padding="30,15,30,20" ColumnSpacing="10">
                    <Border Grid.Column="1" BackgroundColor="#E0E0E0"
                            StrokeShape="RoundRectangle 20" Stroke="Transparent" Padding="25,10">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="Annuler"/>
                        </Border.GestureRecognizers>
                        <Label Text="Annuler" TextColor="#333" FontSize="14" FontAttributes="Bold"/>
                    </Border>
                    <Border Grid.Column="2" BackgroundColor="#1E40AF"
                            StrokeShape="RoundRectangle 20" Stroke="Transparent" Padding="25,10">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="Enregistrer"/>
                        </Border.GestureRecognizers>
                        <Label Text="Enregistrer" TextColor="White" FontSize="14" FontAttributes="Bold"/>
                    </Border>
                </Grid>

            </Grid>
        </Border>
    </Grid>
</ContentPage>
